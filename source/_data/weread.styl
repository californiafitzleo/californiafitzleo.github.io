// ==========================================
// 微信读书划线卡片样式
// 修改此文件可自定义展示效果
// ==========================================

// --- 默认主题（蓝紫渐变边框）---
.weread-card
  position: relative
  border-radius: 12px
  padding: 16px 20px
  margin: 16px 0
  font-size: 1em
  line-height: 1.8
  transition: all 0.3s ease
  background: linear-gradient(#fff, #fff) padding-box,
              linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%) border-box
  border: 2px solid transparent

  .weread-text
    display: block
    color: #4a4a6a
    text-indent: 2em

  &:hover
    box-shadow: 0 8px 25px rgba(102, 126, 234, 0.2)
    transform: translateY(-2px)

// --- 温馨主题 ---
.weread-card.theme-warm
  background: linear-gradient(#fefaf0, #fefaf0) padding-box,
              linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%) border-box

  .weread-text
    color: #5a6c8a
    text-indent: 2em

// --- 极简主题 ---
.weread-card.theme-minimal
  background: transparent
  border: none
  border-left: 3px solid
  border-image: linear-gradient(180deg, #667eea, #764ba2, #f093fb) 1
  padding-left: 14px
  margin: 14px 0
  font-style: italic
  color: #666
  border-radius: 0

  .weread-text
    color: #666
    text-indent: 2em

// --- 深色主题 ---
.weread-card.theme-dark
  background: linear-gradient(#3a3a4a, #3a3a4a) padding-box,
              linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%) border-box

  .weread-text
    color: #e0e0e0
    text-indent: 2em

// --- 划线序号样式（如果启用 show_number）---
.weread-number
  display: inline-block
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%)
  color: #fff
  font-size: 0.75em
  font-weight: bold
  padding: 2px 8px
  border-radius: 10px
  margin-right: 10px