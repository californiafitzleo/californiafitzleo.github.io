// ==========================================
// 微信读书划线卡片样式
// 修改此文件可自定义展示效果
// ==========================================

// --- 默认主题（暖色卡片）---
.weread-card
  background: linear-gradient(135deg, #fff9c4 0%, #fff3e0 100%)
  border-radius: 8px
  padding: 14px 18px
  margin: 12px 0
  border-left: 4px solid #ffb74d
  font-size: 1em
  line-height: 1.7
  transition: all 0.2s ease

  .weread-text
    color: #333

  &:hover
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1)
    transform: translateX(4px)

// --- 温馨主题 ---
.weread-card.theme-warm
  background: #fef6e4
  border-radius: 12px
  padding: 16px 20px
  margin: 16px 0
  border: 1px solid #f3d2c1
  font-size: 1.05em
  line-height: 1.8

  .weread-text
    color: #172c66

// --- 极简主题 ---
.weread-card.theme-minimal
  background: transparent
  border-left: 3px solid #999
  padding-left: 14px
  margin: 14px 0
  font-style: italic
  color: #555

  .weread-text
    color: #555

// --- 深色主题 ---
.weread-card.theme-dark
  background: #2d2d2d
  border-radius: 8px
  padding: 14px 18px
  margin: 12px 0
  border-left: 4px solid #64b5f6

  .weread-text
    color: #e0e0e0

// --- 划线序号样式（如果启用 show_number）---
.weread-number
  display: inline-block
  background: #ffb74d
  color: #fff
  font-size: 0.75em
  font-weight: bold
  padding: 2px 6px
  border-radius: 4px
  margin-right: 8px